# ============================================================
# Teradata Local Lakehouse — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Host machine IP (reachable from Teradata — used for NOS foreign tables and OTF) ---
# Run: ip addr show | grep '192.168' to find the right IP on the Docker host
HOST_IP=<your-docker-host-ip>

# --- Teradata Database (external, not in Docker) ---
TD_HOST=<change_me>
TD_USER=<change_me>
TD_PASSWORD=<change_me>
TD_DATABASE=lakehouse_demo

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Hive Metastore ---
HIVE_DB_HOSTNAME=mysql
HIVE_DB_NAME=metastore
HIVE_DB_USER=hive
HIVE_DB_PASSWORD=hive

# --- MySQL (Hive backend) ---
MYSQL_ROOT_PASSWORD=<change_me>
MYSQL_DATABASE=metastore
MYSQL_USER=hive
MYSQL_PASSWORD=hive
